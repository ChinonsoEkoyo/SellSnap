generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  password      String?
  businessName  String?   @map("business_name")
  image         String?
  accounts      Account[]
  sessions      Session[]
  products      Product[]
  orders        Order[]

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Product {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  slug           String   @unique
  name           String
  description    String?
  price          Int      // Stored in kobo
  imageUrl       String?  @map("image_url")
  imageUrls      String?  @map("image_urls") // JSON array of image URLs
  stockType      String   @default("unlimited") @map("stock_type") // "limited" or "unlimited"
  stockQuantity  Int?     @map("stock_quantity")
  isPublished    Boolean  @default(false) @map("is_published")
  
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders         Order[]

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("products")
}

model Order {
  id               String   @id @default(cuid())
  userId           String?  @map("user_id")
  productId        String   @map("product_id")
  buyerName        String   @map("buyer_name")
  buyerEmail       String   @map("buyer_email")
  buyerPhone       String?  @map("buyer_phone")
  deliveryAddress  String?  @map("delivery_address")
  quantity         Int      @default(1)
  amount           Int      // Stored in kobo, total (price * qty)
  status           String   @default("pending") // pending, paid, failed
  
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user             User?    @relation(fields: [userId], references: [id])
  payment          Payment?

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("orders")
}

model Payment {
  id               String   @id @default(cuid())
  orderId          String   @unique @map("order_id")
  gatewayReference String   @unique @map("gateway_reference") // Paystack transaction reference
  amount           Int      // Stored in kobo
  currency         String   @default("NGN")
  status           String   @default("pending")
  
  order            Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("payments")
}
